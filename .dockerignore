# ==========================================
# .dockerignore cho Laravel + Kubernetes
# ==========================================

# 1. Bảo mật & Môi trường (BẮT BUỘC)
.env
.env.*
!.env.example

# 2. Git & Version Control
.git/
.gitattributes
.gitignore

# 3. Dependencies (Để Dockerfile tự chạy composer install sạch sẽ)
vendor/
node_modules/

# 4. IDE & Editor
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# 5. Logs, Cache & Storage (Giữ cấu trúc thư mục, không copy dữ liệu rác)
storage/logs/*.log
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
storage/*.key

# 6. CI/CD, Testing & Security (Không cần trong Production Image)
.phpunit.result.cache
coverage/
cicd/
Jenkinsfile
.gitleaks.toml
gitleaks-report.json
phpunit.xml
phpunit.xml.dist

# 7. Docker, Kubernetes & Helm
Dockerfile
docker-compose.yml
docker/
Chart.yaml
values.yaml
.helmignore
*.tgz

# 8. Frontend Build Tools (Jenkins đã build sẵn, chỉ cần giữ lại public/build)
tailwind.config.js
vite.config.js
package.json
package-lock.json