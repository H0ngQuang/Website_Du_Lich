pipeline {
    agent any

    environment {
        HARBOR_URL    = '192.168.92.128:8088' 
        HARBOR_PROJ   = 'laravel'
        DOCKER_IMAGE  = "${HARBOR_URL}/${HARBOR_PROJ}/website-du-lich"
        HELM_CHART    = './cicd/L02'
        HELM_RELEASE  = 'laravel-release'
        K8S_NAMESPACE = 'default'
        GITLEAKS_IMAGE = 'zricethezav/gitleaks:v8.18.4' 
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10', daysToKeepStr: '3'))
        timeout(time: 30, unit: 'MINUTES')
    }
    
    stages {
        stage('1. Checkout') {
            steps {
                echo '📥 Đang lấy code...'
                checkout scm
            }
        }

        stage('1.2 Security Scan') {
            steps {
                sh """
                    docker run --rm -v \$(pwd):/src ${GITLEAKS_IMAGE} detect --source=/src --verbose --exit-code 1 || true
                """
            }
        }

        // ✅ GỘP ĐƠN GIẢN: Chạy Test và Build Frontend liên tiếp
        stage('2. Test & Build Assets') {
            steps {
                echo '🚀 Đang chạy Unit Test và Build Frontend...'
                sh '''
                    # 1. Chạy PHP Test
                    docker run --rm -v $(pwd):/app -w /app php:8.3-cli sh -c "
                        apt-get update && apt-get install -y libzip-dev libpng-dev &&
                        docker-php-ext-install zip gd pdo_mysql &&
                        curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer &&
                        composer install --no-interaction &&
                        cp .env.example .env && php artisan key:generate &&
                        php artisan test --testsuite=Unit
                    "

                    # 2. Build Frontend
                    docker run --rm -v $(pwd):/app -w /app node:18-alpine sh -c "
                        npm ci && npm run build
                    "
                    
                    echo '✅ Hoàn tất Test và Build!'
                '''
            }
        }

        stage('3. Build Docker Image') {
            steps {
                echo '🐳 Đang build Docker image (sẽ copy vendor và public/build có sẵn)...'
                sh '''
                    docker build --cache-from ${DOCKER_IMAGE}:latest \
                        -t ${DOCKER_IMAGE}:${BUILD_NUMBER} \
                        -t ${DOCKER_IMAGE}:latest \
                        -f cicd/Dockerfile .
                '''
            }
        }

        stage('4. Push to Harbor') {
            steps {
                echo '📤 Đang push image...'
                withCredentials([usernamePassword(credentialsId: 'harbor-credentials', passwordVariable: 'HARBOR_PASS', usernameVariable: 'HARBOR_USER')]) {
                    sh '''
                        echo "$HARBOR_PASS" | docker login ${HARBOR_URL} -u ${HARBOR_USER} --password-stdin
                        docker push ${DOCKER_IMAGE}:${BUILD_NUMBER}
                        docker push ${DOCKER_IMAGE}:latest
                    '''
                }
            }
        }

        stage('5. Push Helm & Deploy') {
            steps {
                echo '📦 Push Helm và Deploy...'
                withCredentials([usernamePassword(credentialsId: 'harbor-credentials', passwordVariable: 'HARBOR_PASS', usernameVariable: 'HARBOR_USER')]) {
                    sh '''
                        # Push Helm
                        CHART_FILE=$(helm package ${HELM_CHART} --version 0.1.${BUILD_NUMBER} --destination ./cicd/ | awk '{print $NF}')
                        helm registry login ${HARBOR_URL} -u ${HARBOR_USER} -p ${HARBOR_PASS} --plain-http
                        helm push ${CHART_FILE} oci://${HARBOR_URL}/${HARBOR_PROJ} --plain-http

                        # Deploy
                        rm -rf ./deploy && mkdir -p ./deploy
                        helm pull oci://${HARBOR_URL}/${HARBOR_PROJ}/website-du-lich --version 0.1.${BUILD_NUMBER} --plain-http --untar --untardir ./deploy
                        
                        helm upgrade --install ${HELM_RELEASE} ./deploy/website-du-lich \
                            --namespace ${K8S_NAMESPACE} --create-namespace \
                            --set image.repository=${DOCKER_IMAGE} --set image.tag=${BUILD_NUMBER} \
                            --wait --timeout 300s
                    '''
                }
            }
        }
    }

    // ✅ DỌN DẸP ĐƠN GIẢN
    post {
        always {
            echo '🧹 Dọn dẹp workspace và docker...'
            sh '''
                # Xóa thư mục nặng (thêm || true để không fail pipeline nếu không xóa được)
                rm -rf vendor node_modules public/build || true
                
                # Dọn docker cache cũ
                docker system prune -f --filter "until=24h" || true
            '''
        }
        success { echo '🎉 Pipeline thành công!' }
        failure { echo '❌ Pipeline thất bại!' }
    }
}