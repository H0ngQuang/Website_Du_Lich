pipeline {
    agent any

    environment {
        // Cập nhật IP Harbor của bạn
        HARBOR_URL    = '192.168.92.128:8088' 
        HARBOR_PROJ   = 'laravel'
        DOCKER_IMAGE  = "${HARBOR_URL}/${HARBOR_PROJ}/website-du-lich"
        
        HELM_CHART    = './cicd/L02'
        HELM_RELEASE  = 'laravel-release'
        K8S_NAMESPACE = 'default'
        
        // Thông tin đăng nhập Harbor (Sửa mật khẩu cho đúng với máy bạn)
        HARBOR_USER   = 'admin'
        HARBOR_PASS   = 'Harbor12345' // ️ THAY BẰNG MẬT KHẨU HARBOR THỰC TẾ CỦA BẠN
    
        // Cấu hình gitleaks
        GITLEAKS_IMAGE = 'zricethezav/gitleaks:v8.18.4' 
    }
    options {
        // Tự động xóa builds cũ
        buildDiscarder(logRotator(
            numToKeepStr: '10',           // Giữ 10 builds gần nhất
            daysToKeepStr: '3',           // Giữ 3 ngày
            artifactNumToKeepStr: '5',    // Giữ 5 artifacts
            artifactDaysToKeepStr: '7'
        ))
        
        // Timeout pipeline sau 30 phút
        timeout(time: 30, unit: 'MINUTES')
    }
    
    stages {
        // STAGE 1: Checkout code từ GitHub
        stage('1. Checkout') {
            steps {
                echo '📥 Stage 1: Dang lay code tu GitHub...'
                sh 'echo "✅ Da checkout thanh cong!"'
                sh 'ls -la'
            }
        }
        stage ('1.2 Security Scan Gitleaks'){
            steps{
                script {
                    def status = sh(
                        script: """
                            docker run --rm \
                                -v \$(pwd):/src \
                                ${GITLEAKS_IMAGE} detect \
                                --source=/src \
                                --config=/src/.gitleaks.toml \
                                --verbose \
                                --redact \
                                --exit-code 1 \
                                --report-format=json \
                                --report-path=/src/gitleaks-report.json
                        """,
                        returnStatus: true
                    )
                    if (status != 0) {
                        archiveArtifacts artifacts: 'gitleaks-report.json', allowEmptyArchive: true
                        error("🚨 Gitleaks: Phat hien secret bi lo! Pipeline bi chan.")
                    }
                    echo "✅ [Gitleaks] Khong phat hien secret."                
                }
            }
        }
        // STAGE : Build builder Image && Run Test 
        stage ('2. Build Builder Image && Run Test') {
            steps {
                sh '''
                    docker build --target builder -t laravel-builder:${BUILD_NUMBER} -f cicd/Dockerfile .

                    # Chạy test trên image này
                    docker run --rm laravel-builder:${BUILD_NUMBER} \
                        sh -c "cp .env.example .env && php artisan key:generate && php artisan test -- testsuite=Unit"
                '''
            }
        }
        // STAGE : Build Docker Image
        stage('3.Build Docker Image') {
            steps {
                echo ' Stage 3: Dang build Docker image...'
                sh '''
                    docker build \
                        -- target production \
                        -t ${DOCKER_IMAGE}:${BUILD_NUMBER} \
                        -t ${DOCKER_IMAGE}:latest \
                        -f cicd/Dockerfile .
                '''
                echo "✅ Da build image: ${DOCKER_IMAGE}:${BUILD_NUMBER}"
            }
        }

        // STAGE : Push Image lên Harbor Registry
        stage('4. Push to Harbor') {
            steps {
                echo ' Stage 4: Dang push image len Harbor...'
                
                // Login vào Harbor trước khi push
                sh 'docker login -u ${HARBOR_USER} -p ${HARBOR_PASS} ${HARBOR_URL}'
                
                sh '''
                    docker push ${DOCKER_IMAGE}:${BUILD_NUMBER}
                    docker push ${DOCKER_IMAGE}:latest
                '''
                echo "✅ Da push thanh cong: ${DOCKER_IMAGE}:${BUILD_NUMBER}"
            }
        }

        stage('5. Push to Helm') {
            steps {
                echo '📦 Stage 5: Dang push Helm chart len Harbor...'
                sh '''
                    # Package Helm chart
                    helm package ${HELM_CHART} \
                        --version 0.1.${BUILD_NUMBER} \
                        --destination ./cicd/
                    
                    # Login vào Harbor (thêm --plain-http)
                    helm registry login ${HARBOR_URL} \
                        -u ${HARBOR_USER} \
                        -p ${HARBOR_PASS} \
                        --plain-http
                    
                    # Tìm file .tgz vừa tạo
                    CHART_FILE=$(ls -t ./cicd/*.tgz | head -1)
                    echo "📦 Dang push file: ${CHART_FILE}"
                    
                    # Push lên Harbor (thêm --plain-http)
                    helm push ${CHART_FILE} oci://${HARBOR_URL}/${HARBOR_PROJ} \
                        --plain-http
                '''
                echo "✅ Da push Helm chart len Harbor!"
            }
        }

        stage('6. Deploy to K8s') {
            steps {
                echo '☸️ Stage 7: Dang deploy len Kubernetes...'
                
                sh '''
                    # 0. DỌN DẸP THƯ MỤC CŨ (Fix lỗi "already exists")
                    rm -rf ./deploy
                    mkdir -p ./deploy
                    
                    # 1. Login vào Harbor để pull Helm chart
                    helm registry login ${HARBOR_URL} \
                        -u ${HARBOR_USER} \
                        -p ${HARBOR_PASS} \
                        --plain-http
                    
                    # 2. Pull Helm chart từ Harbor về
                    helm pull oci://${HARBOR_URL}/${HARBOR_PROJ}/website-du-lich \
                        --version 0.1.${BUILD_NUMBER} \
                        --plain-http \
                        --untar \
                        --untardir ./deploy
                    
                    # 3. Deploy lên Kubernetes
                    helm upgrade --install ${HELM_RELEASE} ./deploy/website-du-lich \
                        --namespace ${K8S_NAMESPACE} \
                        --create-namespace \
                        --set image.repository=${DOCKER_IMAGE} \
                        --set image.tag=${BUILD_NUMBER} \
                        --set image.pullPolicy=Always \
                        --wait \
                        --timeout 600s
                        
                    # 4. Kiểm tra trạng thái deployment
                    kubectl get pods -n ${K8S_NAMESPACE}
                    kubectl get svc -n ${K8S_NAMESPACE}
                '''
                
                echo "✅ Deploy thanh cong ban ${BUILD_NUMBER}!"
            }
        }
    }

    post {
        success {
            echo '🎉 Pipeline hoan thanh thanh cong!'
        }
        failure {
            echo '❌ Pipeline that bai! Hay kiem tra log de debug.'
        }
        always {
            echo '🧹 Dang don dep...'
            sh '''
                # 1. Xóa image builder (luôn xóa, không cần thiết nữa)
                    docker rmi laravel-builder:${BUILD_NUMBER} 2>/dev/null || true
                    
                    # 2. Xóa image production cũ (chỉ giữ bản mới nhất)
                    # Nếu build lỗi ở Stage 3, 4, 5, 6 → image có thể không tồn tại → || true
                    docker rmi ${DOCKER_IMAGE}:latest 2>/dev/null || true
                    docker rmi ${DOCKER_IMAGE}:${BUILD_NUMBER} 2>/dev/null || true
                    
                    # 3. Xóa dangling images (image không có tag)
                    docker image prune -f
                    
                    # 4. Xóa container stopped
                    docker container prune -f
                    
                    # 5. Xóa build cache (giải phóng space)
                    docker builder prune -f
                    
                    # 6. Dọn dẹp toàn bộ system (optional, có thể comment nếu muốn giữ cache)
                    docker system prune -af --volumes || true
                    
                    echo "✅ Da don dep xong!"
            '''
        }
    }
}