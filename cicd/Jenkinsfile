pipeline {
    agent any

    environment {
        HARBOR_URL    = '192.168.92.128:8088' 
        HARBOR_PROJ   = 'laravel'
        DOCKER_IMAGE  = "${HARBOR_URL}/${HARBOR_PROJ}/website-du-lich"
        HELM_CHART    = './cicd/L02'
        HELM_RELEASE  = 'laravel-release'
        K8S_NAMESPACE = 'default'
        GITLEAKS_IMAGE = 'zricethezav/gitleaks:v8.18.4' 
        NVD_API_KEY = credentials('nvd-api-key')
        
        SONAR_SCANNER_HOME = tool 'SonarScanner' 
   
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10', daysToKeepStr: '3'))
        timeout(time: 30, unit: 'MINUTES')
    }
    
    stages {
        stage('1. Checkout') {
            steps {
                echo '📥 Đang lấy code...'
                checkout scm
            }
        }

        stage('1.2 Security Scan') {
            steps {
                sh """
                    docker run --rm -v \$(pwd):/src ${GITLEAKS_IMAGE} detect --source=/src --verbose --exit-code 1 || true
                """
            }
        }
        stage('Stage 1.3 OWASP Dependency Check (Docker)') {
            steps {
                script {
                    echo '🔍 Khởi chạy OWASP Dependency-Check trong Docker...'
                    sh 'mkdir -p owasp-reports'
                    
                    sh """
                        docker run --rm \\
                            --user root \\
                            -e JAVA_OPTS="-Xmx2g -Xms1g" \\
                            -v ${WORKSPACE}:/src \\
                            -v owasp-nvd-data:/usr/share/dependency-check/data \\
                            -v ${WORKSPACE}/owasp-reports:/report \\
                            owasp/dependency-check:latest \\
                            --scan /src \\
                            --project "${JOB_NAME}" \\
                            --format HTML \\
                            --format JSON \\
                            --out /report \\
                            --failOnCVSS 7 \\
                            --nvdApiKey "${NVD_API_KEY}" \\
                            --exclude "**/node_modules/**" \\
                            --exclude "**/vendor/**" \\
                            --exclude "**/tests/**" \\
                            --exclude "**/.git/**" \\
                            --exclude "**/storage/**" \\
                            --exclude "**/bootstrap/cache/**"
                    """
                }
            }
        }
        
        // ✅ GỘP ĐƠN GIẢN: Chạy Test và Build Frontend liên tiếp
        stage('2. Test & Build Assets') {
            steps {
                echo '🚀 Đang chạy Unit Test và Build Frontend...'
                sh '''
                    # 1. Chạy PHP Test
                    docker run --rm -v $(pwd):/app -w /app php:8.3-cli sh -c "
                        apt-get update && apt-get install -y libzip-dev libpng-dev &&
                        docker-php-ext-install zip gd pdo_mysql &&
                        curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer &&
                        composer install --no-interaction &&
                        cp .env.example .env && php artisan key:generate &&


                        # Tạo thư mục coverage
                        mkdir -p coverage &&
                        
                        # Chạy PHPUnit trực tiếp để xuất file clover.xml (QUAN TRỌNG CHO SONAR)
                        "./vendor/bin/phpunit --coverage-clover=coverage/clover.xml --log-junit=coverage/junit.xml"
                    "

                    # 2. Build Frontend
                    docker run --rm -v $(pwd):/app -w /app node:18-alpine sh -c "
                        npm ci && npm run build
                    "
                    
                    echo '✅ Hoàn tất Test và Build!'
                '''
            }
        }
        
        // stage('3. SonarQube Analysis') {
        //     steps {
        //         echo '🔍 Đang quét mã nguồn với SonarQube...'
        //         // 'SonarQube-Server' là tên bạn đặt trong Manage Jenkins -> System
        //         withSonarQubeEnv('SonarQube-Server') {
        //             sh """
        //                 ${SONAR_SCANNER_HOME}/bin/sonar-scanner \
        //                     -Dsonar.projectKey=laravel-website-du-lich \
        //                     -Dsonar.projectName='Website Du Lich Laravel' \
        //                     -Dsonar.projectVersion=1.0.${BUILD_NUMBER} \
        //                     -Dsonar.sources=app,config,database,routes,resources \
        //                     -Dsonar.tests=tests \
        //                     -Dsonar.php.coverage.reportPaths=coverage/clover.xml \
        //                     -Dsonar.php.tests.reportPath=coverage/junit.xml \
        //                     -Dsonar.exclusions=**/vendor/**,**/node_modules/**,**/storage/**,**/bootstrap/cache/**,**/public/** \
        //                     -Dsonar.qualitygate.wait=true
        //             """
        //         }
        //     }
        // }

        // stage('4. Quality Gate Check') {
        //     steps {
        //         echo '⏳ Đang chờ kết quả Quality Gate từ SonarQube...'
        //         timeout(time: 5, unit: 'MINUTES') {
        //             waitForQualityGate abortPipeline: true
        //         }
        //     }
        // }
        
        stage('3. Build Docker Image') {
            steps {
                echo '🐳 Đang build Docker image (sẽ copy vendor và public/build có sẵn)...'
                sh '''
                    docker build --cache-from ${DOCKER_IMAGE}:latest \
                        -t ${DOCKER_IMAGE}:${BUILD_NUMBER} \
                        -t ${DOCKER_IMAGE}:latest \
                        -f cicd/Dockerfile .
                '''
            }
        }

        stage('4. Push to Harbor') {
            steps {
                echo '📤 Đang push image...'
                withCredentials([usernamePassword(credentialsId: 'harbor-credentials', passwordVariable: 'HARBOR_PASS', usernameVariable: 'HARBOR_USER')]) {
                    sh '''
                        echo "$HARBOR_PASS" | docker login ${HARBOR_URL} -u ${HARBOR_USER} --password-stdin
                        docker push ${DOCKER_IMAGE}:${BUILD_NUMBER}
                        docker push ${DOCKER_IMAGE}:latest
                    '''
                }
            }
        }

        stage('5. Push Helm & Deploy') {
            steps {
                echo '📦 Push Helm và Deploy...'
                withCredentials([usernamePassword(credentialsId: 'harbor-credentials', passwordVariable: 'HARBOR_PASS', usernameVariable: 'HARBOR_USER')]) {
                    sh '''
                        # Push Helm
                        CHART_FILE=$(helm package ${HELM_CHART} --version 0.1.${BUILD_NUMBER} --destination ./cicd/ | awk '{print $NF}')
                        helm registry login ${HARBOR_URL} -u ${HARBOR_USER} -p ${HARBOR_PASS} --plain-http
                        helm push ${CHART_FILE} oci://${HARBOR_URL}/${HARBOR_PROJ} --plain-http

                        # Deploy
                        rm -rf ./deploy && mkdir -p ./deploy
                        helm pull oci://${HARBOR_URL}/${HARBOR_PROJ}/website-du-lich --version 0.1.${BUILD_NUMBER} --plain-http --untar --untardir ./deploy
                        
                        helm upgrade --install ${HELM_RELEASE} ./deploy/website-du-lich \
                            --namespace ${K8S_NAMESPACE} --create-namespace \
                            --set image.repository=${DOCKER_IMAGE} --set image.tag=${BUILD_NUMBER} \
                            --wait --timeout 300s
                    '''
                }
            }
        }
    }

    // ✅ DỌN DẸP ĐƠN GIẢN
    post {
        always {
            echo '🧹 Đang tự động dọn dẹp workspace sau khi build...'
            
            script {
                // 1. Lưu báo cáo OWASP (Jenkins step - đặt NGOÀI sh)
                archiveArtifacts artifacts: 'owasp-reports/dependency-check-report.html', allowEmptyArchive: true
                
                // 2. Dùng plugin cleanWs() để xóa sạch sẽ
                cleanWs(deleteDirs: true, notFailBuild: true)
                
                // 3. Xóa file bằng Docker Alpine (giải quyết vấn đề Permission Denied)
// ĐẶT TRONG "sh" - Đây là lệnh Linux/Docker
                sh '''
                    docker run --rm \\
                        -v $(pwd):/workspace \\
                        alpine:latest \\
                        rm -rf /workspace/vendor \\
                            /workspace/node_modules \\
                            /workspace/public/build \\
                            /workspace/deploy \\
                            /workspace/owasp-reports \\
                        || true
                    
                    rm -f cicd/*.tgz || true
                    docker image prune -f || true
                '''
                }
        }
        success { echo '🎉 Pipeline thành công!' }
        failure { echo '❌ Pipeline thất bại!' }
    }
}   