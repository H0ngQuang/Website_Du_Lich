pipeline {
    agent any

    environment {
        // Cập nhật IP Harbor của bạn
        HARBOR_URL    = '192.168.92.128:8088' 
        HARBOR_PROJ   = 'laravel'
        DOCKER_IMAGE  = "${HARBOR_URL}/${HARBOR_PROJ}/website-du-lich"
        
        HELM_CHART    = './cicd/L02'
        HELM_RELEASE  = 'laravel-release'
        K8S_NAMESPACE = 'default'
        
        // Thông tin đăng nhập Harbor (Sửa mật khẩu cho đúng với máy bạn)
        HARBOR_USER   = 'admin'
        HARBOR_PASS   = 'Harbor12345' // ️ THAY BẰNG MẬT KHẨU HARBOR THỰC TẾ CỦA BẠN
    }

    stages {
        // STAGE 1: Checkout code từ GitHub
        stage('1. Checkout') {
            steps {
                echo '📥 Stage 1: Dang lay code tu GitHub...'
                sh 'echo "✅ Da checkout thanh cong!"'
                sh 'ls -la'
            }
        }

        // STAGE 2: Build Docker Image
        stage('2.Build Docker Image') {
            steps {
                echo ' Stage 2: Dang build Docker image...'
                sh '''
                    docker build \
                        -t ${DOCKER_IMAGE}:${BUILD_NUMBER} \
                        -t ${DOCKER_IMAGE}:latest \
                        -f cicd/Dockerfile .
                '''
                echo "✅ Da build image: ${DOCKER_IMAGE}:${BUILD_NUMBER}"
            }
        }

        // STAGE 3: Push Image lên Harbor Registry
        stage('3. Push to Harbor') {
            steps {
                echo ' Stage 3: Dang push image len Harbor...'
                
                // Login vào Harbor trước khi push
                sh 'docker login -u ${HARBOR_USER} -p ${HARBOR_PASS} ${HARBOR_URL}'
                
                sh '''
                    docker push ${DOCKER_IMAGE}:${BUILD_NUMBER}
                    docker push ${DOCKER_IMAGE}:latest
                '''
                echo "✅ Da push thanh cong: ${DOCKER_IMAGE}:${BUILD_NUMBER}"
            }
        }

        // STAGE 4: Đóng gói Helm Chart
        stage('4. Push to Helm') {
            steps {
                echo '📦 Stage 4: Dang dong goi Helm chart...'
                sh '''
                    helm package ${HELM_CHART} \
                        --version ${BUILD_NUMBER} \
                        --destination ./cicd/
                '''
                echo '✅ Helm chart da duoc dong goi!'
            }
        }

        // STAGE 5: Deploy lên Kubernetes
        stage('5. Deploy to K8s') {
            steps {
                echo '☸️ Stage 5: Dang deploy len Kubernetes...'
                sh '''
                    helm upgrade --install ${HELM_RELEASE} ${HELM_CHART} \
                        --namespace ${K8S_NAMESPACE} \
                        --set image.tag=${BUILD_NUMBER} \
                        --set image.repository=${DOCKER_IMAGE} \
                        --wait --timeout 300s
                '''
                echo "✅ Deploy thanh cong ban ${BUILD_NUMBER}!"
            }
        }
    }

    post {
        success {
            echo '🎉 Pipeline hoan thanh thanh cong!'
        }
        failure {
            echo '❌ Pipeline that bai! Hay kiem tra log de debug.'
        }
        always {
            echo '🧹 Dang don dep...'
            sh 'docker system prune -af || true'
        }
    }
}